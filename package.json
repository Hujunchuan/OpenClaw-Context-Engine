{
  "name": "openclaw-context-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "tsc --noEmit",
    "demo": "node --loader ts-node/esm src/demo.ts",
    "compare": "node --loader ts-node/esm src/legacy-vs-hypergraph.ts",
    "demo:snapshots": "node --loader ts-node/esm -e \"import('./fixtures/demo-scenarios.ts').then(async ({ runAllDemoScenarios }) => console.log(JSON.stringify(await runAllDemoScenarios(), null, 2)))\"",
    "runtime:demo": "node --loader ts-node/esm src/adapter-runtime-demo.ts",
    "test": "node --loader ts-node/esm --test tests/**/*.test.ts",
    "plugin:check": "node --loader ts-node/esm -e \"import('./src/openclaw-adapter.ts').then(() => console.log('adapter-ok'))\""
  },
  "devDependencies": {
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
